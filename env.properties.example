# ─────────────────────────────────────────────────────────────────────────────
# Template for rag-search-engine/env.properties
#
# Copy this file to env.properties (same directory) and fill in real values.
# env.properties is gitignored and never committed.
#
# Mechanism:
#   • mvn test / mvn install        → Surefire reads this file via
#                                     <systemPropertiesFile> and exposes every
#                                     entry as a JVM system property before any
#                                     test class loads.
#   • mvn spring-boot:run / IDE     → EnvFilePropertyLoader (an
#                                     EnvironmentPostProcessor) reads it on
#                                     Spring Boot startup and copies entries
#                                     to System properties.
#
# Either path, the same code (SecretManagerService, @Value resolutions) sees
# the values without changes.  No -D flags required on the command line.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — used by intent parser, reranker, judge
OPENAI_API_KEY=sk-replace-me

# Optional: pin the chat model.  Default is gpt-4o-mini.
# OPENAI_MODEL=gpt-4o-mini

# Optional: override only the function-calling (intent parser) model.
# Falls back to OPENAI_MODEL.  Useful for cost-comparison runs.
# OPENAI_FUNCTION_MODEL=gpt-4

# Pinecone — vector store for category + product embeddings
PINECONE_API_KEY=pcsk-replace-me

# LangSmith — tracing + LLM-as-judge feedback
LANGSMITH_API_KEY=lsv2_pt_replace_me
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=rag-search-engine
# Project UUID (visible in the LangSmith project URL after /p/).
# Required by LangSmithFeedbackService to resolve the LangSmith run_id from
# the OTel trace_id when posting judge feedback.
LANGSMITH_SESSION_ID=00000000-0000-0000-0000-000000000000
